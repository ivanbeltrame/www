---
import { undefined } from "astro:schema";

const { title, category, id, link } = Astro.props;
---
<div class="customCard card text-center m-2">
    <div class="card-body">
        <h5 class="card-title">{ title }</h5>
        <img src={`/img/certificates/${ category }/${id}.jpg`} alt={`Certificato ${ title }`} class="card-img" loading="lazy">
        <div class="d-flex justify-content-around align-items-center mt-3">
            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target={`#${ category }-${ id }-modal`}>
                Zoom
            </button>
            <div class="modal fade" id={`${ category }-${ id }-modal`} tabindex="-1" aria-labelledby={`${ category }-${ id }-modal-label`} aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered modal-xl">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h1 class="modal-title fs-5 mx-auto" id={`${ category }-${ id }-modal-label`}>{ title }</h1>
                            <button type="button" class="btn-close mx-0" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <img src={`/img/certificates/${ category }/${ id }.jpg`} alt={`Certificato ${ title }`} loading="lazy" class="w-100">
                    </div>
                </div>
            </div>
            { link !== undefined && (
                <a href={ link } class="card-link" target="_blank" rel="noopener noreferrer">Link</a>
            )}
        </div>
    </div>
</div>