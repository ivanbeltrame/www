---
import { Image } from "astro:assets";
const { title, category, id, link, mainPic, imgs, eagerLoading } = Astro.props;
---
<div class="customCard card text-center m-2">
    <div class="card-body">
        <h5 class="card-title">{ title }</h5>
        {eagerLoading ? (
            <Image src={ mainPic } alt={`Certificato ${ title }`} class="card-img w-100 h-auto" loading="eager" />
        ) : (
            <Image src={ mainPic } alt={`Certificato ${ title }`} class="card-img w-100 h-auto" />
        )}
        <div class="d-flex justify-content-around align-items-center mt-3">
            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target={`#${ category }-${ id }-modal`}>Zoom</button>
            <div class="modal fade" id={`${ category }-${ id }-modal`} tabindex="-1" aria-labelledby={`${ category }-${ id }-modal-label`} aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered modal-xl">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h1 class="modal-title fs-5 mx-auto" id={`${ category }-${ id }-modal-label`}>{ title }</h1>
                            <button type="button" class="btn-close mx-0" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <div id={`${ category }-${ id }-carousel`} class="carousel slide">
                                <div class="carousel-inner">
                                    <div class="carousel-item active">
                                        <Image src={ mainPic } class="d-block w-100 h-auto" alt={`Certificato ${ title }`} />
                                    </div>
                                    { imgs.map((img) => (
                                        <div class="carousel-item">
                                            <Image src={ img } class="d-block w-100 h-auto" alt={`Certificato ${ title }`} />
                                        </div>
                                    ))}
                                </div>
                                <button class="carousel-control-prev" type="button" data-bs-target={`#${ category }-${ id }-carousel`} data-bs-slide="prev">
                                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                    <span class="visually-hidden">Precedente</span>
                                </button>
                                <button class="carousel-control-next" type="button" data-bs-target={`#${ category }-${ id }-carousel`} data-bs-slide="next">
                                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                    <span class="visually-hidden">Prossimo</span>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            { link && (
                <a href={ link } class="card-link" target="_blank" rel="noopener noreferrer">Link</a>
            )}
        </div>
    </div>
</div>