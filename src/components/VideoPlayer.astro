---
const { link, title, thumbnail } = Astro.props;
---
<div class="row my-5 text-start">
    <div class="col">
        <a href={ link } target="_blank" rel="noopener noreferrer">
            <div class="videoPlayer">
                <img class="border border-secondary-subtle w-100 videoThumbnail" src={ `/img/videos/${ thumbnail }.jpg` } alt={ title } loading="lazy">
                <i class="bi bi-play-btn-fill fs-1 text-danger playButton"></i>
            </div>
        </a>
    </div>
    <div class="col">
        <h3 class="fw-bold">{ title }</h3>
        <p><slot /></p>
    </div>
</div>